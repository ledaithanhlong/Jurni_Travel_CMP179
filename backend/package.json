{
  "name": "traveloka-clone-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "migrate:mysql-to-mongo": "node src/scripts/migrate-mysql-to-mongo.js",
    "db:create": "sequelize db:create --config src/config/database.cjs",
    "db:migrate": "sequelize db:migrate --config src/config/database.cjs --migrations-path src/migrations",
    "db:migrate:undo": "sequelize db:migrate:undo --config src/config/database.cjs --migrations-path src/migrations",
    "db:seed": "sequelize db:seed:all --config src/config/database.cjs",
    "db:seed:undo": "sequelize db:seed:undo:all --config src/config/database.cjs"
  },
  "dependencies": {
    "@clerk/express": "^1.3.20",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.3",
    "mongoose": "^8.19.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.3"
  }
}
